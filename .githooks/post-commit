#!/usr/bin/env bash
# Regenerates index.scip after each commit in the background.
# The index is queried by Claude Code sessions via scripts/scip-query.py.

REPO_ROOT="$(git rev-parse --show-toplevel)"
LOG="$REPO_ROOT/.scip-index.log"

(
  cd "$REPO_ROOT"
  dotnet tool restore --no-cache > /dev/null 2>&1
  dotnet tool run scip-dotnet index WorldEngine.sln \
    --output index.scip \
    --skip-dotnet-restore \
    >> "$LOG" 2>&1
  echo "$(date -Is) indexed $(git rev-parse --short HEAD)" >> "$LOG"
) &
